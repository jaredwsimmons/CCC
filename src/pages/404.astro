---
import Base from '../layouts/Base.astro';
import Quatrefoil from '../components/Quatrefoil.astro';
import Icon from '../components/Icon.astro';
---
<Base title="Page not found" description="We couldn't find that page.">
  <section class="nf">
    <Quatrefoil size={520} class="nf__wm" />
    <div class="container nf__inner">
      <p class="eyebrow on-dark">404</p>
      <h1>We couldn't find that page</h1>
      <p class="lead">The link may be old or mistyped — but you're still welcome here. Let's get you back on track.</p>
      <div class="cta-row mt-1">
        <a class="btn btn--gold btn--lg" href="/">Back home <Icon name="arrow" size={18} /></a>
        <a class="btn btn--on-dark" href="/imnew">Plan a visit</a>
      </div>
    </div>
  </section>
</Base>

<style>
  .nf { position: relative; overflow: hidden; background: var(--grad-hero); color: #dbe8f4; min-height: 60vh; display: grid; align-items: center; padding-block: clamp(3rem, 8vw, 6rem); }
  .nf__wm { position: absolute; right: -120px; bottom: -160px; color: rgba(255,255,255,0.05); }
  .nf__inner { position: relative; max-width: 640px; }
  .nf h1 { color: #fff; }
  .nf .lead { color: #cddced; margin-top: 1rem; }
</style>
