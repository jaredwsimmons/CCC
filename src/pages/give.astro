---
import Base from '../layouts/Base.astro';
import { site } from '../data/site';
const giveHref = `${site.churchCenter.giving}?open-in-church-center-modal=true`;
---
<Base title="Give" description="Give to Chelsea Community Church securely through Church Center.">
  <section class="give">
    <div class="container">
      <p class="eyebrow">Generosity</p>
      <h1>Give</h1>
      <p class="lead">
        Thank you for partnering in the mission of our church. Giving is secure and handled through
        Church Center — you can give once or set up recurring gifts.
      </p>
      <div class="cta-row">
        <a class="btn btn--gold" href={giveHref}>Give now</a>
        <a class="btn btn--ghost" href={site.churchCenter.giving} target="_blank" rel="noopener noreferrer">Open in a new tab</a>
      </div>
      <p class="fine">
        Prefer the app? <a href={site.churchCenter.appSetup} target="_blank" rel="noopener noreferrer">Get the Church Center app</a>
        to give and stay connected from your phone.
      </p>
    </div>
  </section>
</Base>

<style>
  .give { background: linear-gradient(180deg, var(--blue-tint), #fff); padding-block: clamp(3rem, 8vw, 6rem); }
  .give .lead { font-size: 1.2rem; max-width: 54ch; color: var(--muted); }
  .cta-row { display: flex; flex-wrap: wrap; gap: 0.75rem; margin-top: 1.5rem; }
  .fine { margin-top: 1.5rem; color: var(--muted); font-size: 0.95rem; }
</style>
