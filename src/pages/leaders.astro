---
import Base from '../layouts/Base.astro';
import PageHero from '../components/PageHero.astro';
import Section from '../components/Section.astro';
import { leaders } from '../data/content';
import { site } from '../data/site';
---
<Base title="Leaders" description="The elders, pastors, staff, and deacons of Chelsea Community Church.">
  <PageHero eyebrow="About" title="Leaders" />

  <Section>
    <div class="grid cols-4 staff">
      {leaders.staff.map((p) => (
        <div class="person" data-reveal>
          <div class="person__photo">
            <img src={p.image} alt={`${p.name} — ${p.role}`} loading="lazy" />
          </div>
          <h3>{p.name}</h3>
          <p>{p.role}</p>
        </div>
      ))}
    </div>
  </Section>

  <Section variant="alt" eyebrow="Deacons" title="Serving the body" center>
    <div class="deacons" data-reveal>
      {leaders.deacons.map((d) => (
        <div class="deacon">
          <span class="area">{d.area}</span>
          <span class="names">{d.names}</span>
        </div>
      ))}
    </div>
    <p class="note" data-reveal>
      Questions about our leadership? <a href={`mailto:${site.email}`}>Email the church office</a>.
    </p>
  </Section>
</Base>

<style>
  .staff { gap: 1.75rem 1.25rem; }
  .person { text-align: center; }
  .person__photo {
    aspect-ratio: 3 / 4;
    border-radius: var(--r);
    overflow: hidden;
    border: 1px solid var(--hair);
    box-shadow: var(--shadow);
    background: #fff;
    margin-bottom: 0.8rem;
  }
  /* portrait headshots (~0.7 ratio) — anchor to the top so heads aren't cropped */
  .person__photo img { width: 100%; height: 100%; object-fit: cover; object-position: top center; }
  .person h3 { font-size: 1.08rem; }
  .person p { font-size: 0.88rem; color: var(--mid); }

  .deacons {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(230px, 1fr));
    gap: 0.6rem 1.25rem;
    text-align: left;
    background: #fff;
    border: 1px solid var(--hair);
    border-radius: var(--r);
    box-shadow: var(--shadow);
    padding: clamp(1.25rem, 3vw, 2rem);
  }
  .deacon { display: flex; flex-direction: column; padding-block: 0.35rem; }
  .area {
    font-family: var(--display);
    font-size: 0.72rem;
    font-weight: 600;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--blue);
  }
  .names { font-size: 0.95rem; }
  .note { margin-top: 1.5rem; color: var(--mid); font-size: 0.95rem; }
</style>
