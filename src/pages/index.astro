---
import Base from '../layouts/Base.astro';
import Section from '../components/Section.astro';
import { site, withBase } from '../data/site';
import { home } from '../data/content';

const planVisit = `${site.churchCenter.forms.planVisit}?open-in-church-center-modal=true`;
const give = `${site.churchCenter.giving}?open-in-church-center-modal=true`;
const prayerForm = `${site.churchCenter.forms.prayer}?open-in-church-center-modal=true`;
const address = `${site.address.line1}, ${site.address.city}, ${site.address.state} ${site.address.zip}`;
---
<Base>
  <!-- Hero — the current site's background video over a real photo fallback.
       The photo paints first (and stays for reduced-motion / JS-off / slow
       connections); the video fades over it once it can play. -->
  <section class="hero home-hero">
    <div class="hero__img">
      <img src={home.hero.image} alt={home.hero.imageAlt} loading="eager" fetchpriority="high" />
      <video class="hero__video" autoplay muted loop playsinline preload="metadata" aria-hidden="true" tabindex="-1">
        <source src={withBase('/videos/hero.mp4')} type="video/mp4" />
      </video>
    </div>
    <div class="wrap inner">
      <p class="eyebrow on-dark">A church family in Chelsea, Alabama</p>
      <h1>Pursuing God.<br />Pursuing others.</h1>
      <div class="rule" aria-hidden="true"></div>
      <p class="sub">{home.hero.sub} · <b>{home.hero.times}</b></p>
      <div class="actions">
        <a class="btn btn--gold btn--lg" href={planVisit}>Plan a Visit</a>
        <a class="btn btn--outline-light btn--lg" href={withBase('/imnew')}>I'm New</a>
      </div>
    </div>
  </section>

  <!-- Blue band — this Sunday -->
  <div class="band">
    <div class="wrap">
      <span class="dot" aria-hidden="true"></span>
      <span>This Sunday · 9:00 &amp; 10:30 AM</span>
      <span class="band-addr">{address}</span>
      <a href={site.address.maps} target="_blank" rel="noopener noreferrer">Get directions</a>
    </div>
  </div>

  <!-- Welcome -->
  <Section eyebrow="Welcome" title="Welcome to Chelsea Community Church" center>
    <p class="lead measure" data-reveal>{home.welcome.body}</p>
    <div class="welcome-actions" data-reveal>
      <a class="btn btn--blue" href={withBase('/imnew')}>I'm New</a>
      <a class="btn btn--outline" href={withBase('/beliefs')}>Learn More</a>
    </div>
  </Section>

  <!-- Current series -->
  <Section variant="navy">
    <div class="split">
      <div class="photo" data-reveal>
        <img src={home.series.art} alt={home.series.artAlt} loading="lazy" />
      </div>
      <div data-reveal>
        <p class="eyebrow on-dark">{home.series.eyebrow}</p>
        <h2>Jesus Storyteller</h2>
        <p style="margin-top:0.9rem">{home.series.body}</p>
        <div class="series-actions">
          <a class="btn btn--gold" href={site.media.seriesPlaylist} target="_blank" rel="noopener noreferrer">Watch Service</a>
          <a class="btn btn--outline-light" href={site.social.spotify} target="_blank" rel="noopener noreferrer">Listen on Spotify</a>
        </div>
      </div>
    </div>
  </Section>

  <!-- App spotlight -->
  <Section variant="white" eyebrow="Spotlight" title="New church app">
    <div class="split">
      <div data-reveal>
        <p class="measure">{home.app.body}</p>
        <div class="app-actions">
          <a class="btn btn--blue" href={site.app.ios} target="_blank" rel="noopener noreferrer">App Store</a>
          <a class="btn btn--blue" href={site.app.android} target="_blank" rel="noopener noreferrer">Google Play</a>
          <a class="btn btn--outline" href={site.churchCenter.appSetup} target="_blank" rel="noopener noreferrer">Set up Church Center</a>
        </div>
      </div>
      <div class="photo photo--plain" data-reveal>
        <img src={home.app.image} alt={home.app.imageAlt} loading="lazy" />
      </div>
    </div>
  </Section>

  <!-- Get in touch — the current site's footer tiles, as cards -->
  <Section eyebrow="Get in touch" title="We're here to listen" center>
    <div class="grid cols-4">
      <a class="card touch" href={`mailto:${site.email}`} data-reveal>
        <h3>Email Us</h3>
        <p>Get in touch with us, we're here to listen!</p>
      </a>
      <a class="card touch" href={prayerForm} data-reveal>
        <h3>Prayer</h3>
        <p>Let us know how we can pray for you.</p>
      </a>
      <a class="card touch" href={site.social.facebook} target="_blank" rel="noopener noreferrer" data-reveal>
        <h3>Facebook</h3>
        <p>Connect with us and stay up-to-date!</p>
      </a>
      <a class="card touch" href={site.social.instagram} target="_blank" rel="noopener noreferrer" data-reveal>
        <h3>Instagram</h3>
        <p>Connect with us and stay up-to-date!</p>
      </a>
    </div>
    <p class="visit-line" data-reveal>
      <b>{address}</b> · <a href={`tel:+1${site.phone.replaceAll('-', '')}`}>{site.phone}</a>
    </p>
  </Section>
</Base>

<style>
  .home-hero .inner { padding-block: clamp(4.5rem, 13vw, 8.5rem); }
  .hero__video {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
  }
  @media (prefers-reduced-motion: reduce) {
    .hero__video { display: none; }
  }
  .home-hero h1 { font-size: clamp(2.4rem, 6.5vw, 4.1rem); }
  .home-hero .sub { font-family: var(--display); font-size: clamp(1rem, 2vw, 1.2rem); font-weight: 500; }
  .home-hero .sub b { color: var(--gold); font-weight: 600; }
  .home-hero .actions { display: flex; flex-wrap: wrap; gap: 0.75rem; margin-top: 1.75rem; }

  .band-addr { color: rgba(251, 249, 244, 0.75); }
  @media (max-width: 700px) { .band-addr { display: none; } }

  .welcome-actions { display: flex; justify-content: center; flex-wrap: wrap; gap: 0.75rem; margin-top: 1.5rem; }
  .series-actions, .app-actions { display: flex; flex-wrap: wrap; gap: 0.75rem; margin-top: 1.4rem; }

  .photo--plain { border: 1px solid var(--hair); }

  .touch { text-decoration: none; display: block; transition: transform 0.16s ease, box-shadow 0.16s ease; }
  .touch:hover { transform: translateY(-2px); box-shadow: 0 2px 4px rgba(25,55,79,0.06), 0 14px 30px -12px rgba(25,55,79,0.18); }
  .touch h3 { color: var(--blue); }
  .visit-line { margin-top: 2rem; color: var(--mid); font-size: 0.98rem; }
</style>
