---
import Base from '../layouts/Base.astro';
import PageHero from '../components/PageHero.astro';
import Section from '../components/Section.astro';
import CTABand from '../components/CTABand.astro';
import { site } from '../data/site';
import { imnew } from '../data/content';
const planVisit = `${site.churchCenter.forms.planVisit}?open-in-church-center-modal=true`;
---
<Base title="I'm New" description="What to expect on a Sunday at Chelsea Community Church — services at 9:00 & 10:30 AM, what to wear, where to go first, and how to let us know you're coming.">
  <PageHero
    eyebrow="I'm New"
    title="What to Expect"
    image={imnew.hero.image}
    imageAlt={imnew.hero.imageAlt}
  >
    <a class="btn btn--gold btn--lg" href={planVisit}>Let Us Know You're Coming!</a>
  </PageHero>

  <Section>
    <div class="measure" data-reveal>
      {imnew.expect.map((p) => <p class="expect">{p}</p>)}
    </div>
    <div class="grid cols-2 mt-2">
      <div class="card" data-reveal>
        <h3>{imnew.dress.title}</h3>
        <p>{imnew.dress.body}</p>
      </div>
      <div class="card" data-reveal>
        <h3>{imnew.whereToGo.title}</h3>
        <p>{imnew.whereToGo.body}</p>
      </div>
    </div>
  </Section>

  <Section variant="navy" tight>
    <div class="fam" data-reveal>
      <div>
        <p class="eyebrow on-dark">5th Sundays</p>
        <h2>{imnew.familyWorship.title}</h2>
        <p style="margin-top:0.8rem; max-width:62ch">{imnew.familyWorship.body}</p>
      </div>
    </div>
  </Section>

  <Section eyebrow="Before you arrive" title={imnew.coming.title}>
    <div class="split">
      <div data-reveal>
        <p class="measure">{imnew.coming.body}</p>
        <p class="measure" style="margin-top:0.9rem">{imnew.coming.desk}</p>
        <a class="btn btn--blue mt-1" href={planVisit}>Let Us Know You're Coming!</a>
      </div>
      <div class="photo" data-reveal>
        <img src={imnew.coming.image} alt={imnew.coming.imageAlt} loading="lazy" />
      </div>
    </div>
  </Section>

  <CTABand title="Join us this Sunday" text={`Worship & Community Groups at 9:00 and 10:30 AM · ${site.address.line1}, ${site.address.city}, ${site.address.state}`}>
    <a class="btn btn--gold btn--lg" href={site.address.maps} target="_blank" rel="noopener noreferrer">Get directions</a>
  </CTABand>
</Base>

<style>
  .expect + .expect { margin-top: 0.9em; }
</style>
