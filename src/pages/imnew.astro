---
import Base from '../layouts/Base.astro';
import PageHero from '../components/PageHero.astro';
import Section from '../components/Section.astro';
import CTABand from '../components/CTABand.astro';
import ContactForm from '../components/ContactForm.astro';
import { site } from '../data/site';
import { imnew } from '../data/content';
const planVisit = `${site.churchCenter.forms.planVisit}?open-in-church-center-modal=true`;
---
<Base title="I'm New" description="What to expect on a Sunday at Chelsea Community Church — services at 9:00 & 10:30 AM, what to wear, where to go first, and how to let us know you're coming.">
  <PageHero
    eyebrow="I'm New"
    title="What to Expect"
    image={imnew.hero.image}
    imageAlt={imnew.hero.imageAlt}
  >
    <a class="btn btn--gold btn--lg" href="#visit-form">Let Us Know You're Coming!</a>
  </PageHero>

  <Section>
    <div class="measure" data-reveal>
      {imnew.expect.map((p) => <p class="expect">{p}</p>)}
    </div>
    <div class="grid cols-2 mt-2">
      <div class="card" data-reveal>
        <h3>{imnew.dress.title}</h3>
        <p>{imnew.dress.body}</p>
      </div>
      <div class="card" data-reveal>
        <h3>{imnew.whereToGo.title}</h3>
        <p>{imnew.whereToGo.body}</p>
      </div>
    </div>
  </Section>

  <!-- One "let us know you're coming" moment: the form, with the warm invite as
       its intro and the Connections-Desk alternative + photo alongside. (Merged
       from two back-to-back sections that repeated the same message.) -->
  <Section id="visit-form" variant="alt" eyebrow="Before you arrive" title={imnew.coming.title} lead={imnew.coming.body}>
    <div class="split visit-split">
      <div data-reveal>
        <ContactForm
          formType="visit"
          submitLabel="Let us know you're coming"
          fallbackHref={planVisit}
          fallbackLabel="Prefer our Church Center form?"
          successMsg="We can't wait to meet you! Look for us at the Connections Desk — we'll have something for you."
          fields={[
            { name: 'name', label: 'Your name', required: true, autocomplete: 'name', half: true },
            { name: 'email', label: 'Email', type: 'email', required: true, autocomplete: 'email', half: true },
            { name: 'phone', label: 'Phone (optional)', type: 'tel', autocomplete: 'tel', half: true },
            { name: 'visit_date', label: 'Which Sunday are you thinking?', type: 'text', placeholder: 'e.g. this Sunday, or a date', half: true },
            { name: 'message', label: 'Anything we should know? (kids’ ages, questions…)', type: 'textarea' },
          ]}
        />
      </div>
      <div data-reveal>
        <div class="photo">
          <img src={imnew.coming.image} alt={imnew.coming.imageAlt} loading="lazy" />
        </div>
        <div class="card mt-2">
          <h3>Prefer to connect in person?</h3>
          <p>{imnew.coming.desk}</p>
        </div>
      </div>
    </div>
  </Section>

  <CTABand title="Join us this Sunday" text={`Worship & Community Groups at 9:00 and 10:30 AM · ${site.address.line1}, ${site.address.city}, ${site.address.state}`}>
    <a class="btn btn--gold btn--lg" href={site.address.maps} target="_blank" rel="noopener noreferrer">Get directions</a>
  </CTABand>
</Base>

<style>
  .expect + .expect { margin-top: 0.9em; }
  /* form + supporting column align to the top, not vertically centered */
  .visit-split { align-items: start; }
</style>
