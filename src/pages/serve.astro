---
import Base from '../layouts/Base.astro';
import PageHero from '../components/PageHero.astro';
import Section from '../components/Section.astro';
import CTABand from '../components/CTABand.astro';
import { serve } from '../data/content';
---
<Base title="Serve" description="Find your place, know your purpose, be people of pursuit — the Teams Mobilizer tool at Chelsea Community Church.">
  <PageHero eyebrow="Ministries" title="Serve" lead={`${serve.verse.text} (${serve.verse.ref})`} />

  <Section eyebrow="Teams Mobilizer" title="Find your place. Know your purpose.">
    <div class="split">
      <div data-reveal>
        <div class="measure">
          {serve.intro.map((p) => <p>{p}</p>)}
        </div>
        <a class="btn btn--gold mt-1" href={serve.survey} target="_blank" rel="noopener noreferrer">Click here to take the survey</a>
      </div>
      <div class="photo" data-reveal>
        <img src={serve.image.src} alt={serve.image.alt} loading="lazy" />
      </div>
    </div>
  </Section>

  <Section variant="alt" center>
    <div class="grid cols-2" style="text-align:left">
      <div class="card" data-reveal>
        <h3>It Is:</h3>
        <ul class="list">
          {serve.itIs.map((i) => <li>{i}</li>)}
        </ul>
      </div>
      <div class="card" data-reveal>
        <h3>It Is Not:</h3>
        <ul class="list">
          {serve.itIsNot.map((i) => <li>{i}</li>)}
        </ul>
      </div>
    </div>
  </Section>

  <Section eyebrow="Instructions" title="Three simple steps">
    <div class="grid cols-3">
      {serve.instructions.map((s, i) => (
        <div class="card" data-reveal>
          <p class="step">Step {i + 1}</p>
          <h3>{s.title}</h3>
          <p>{s.body}</p>
        </div>
      ))}
    </div>
    <p class="measure closing" data-reveal>{serve.closing}</p>
  </Section>

  <CTABand title="Questions about serving?" text="Brian Marbury, our Pastor of Missions & Service, is the one to ask.">
    <a class="btn btn--gold btn--lg" href={`mailto:${serve.contact}`}>Email Brian for more information!</a>
  </CTABand>
</Base>

<style>
  .list { list-style: none; display: grid; gap: 0.55rem; margin-top: 0.5rem; }
  .list li { padding-left: 1.1rem; position: relative; font-size: 0.98rem; color: var(--mid); }
  .list li::before {
    content: "";
    position: absolute;
    left: 0;
    top: 0.55em;
    width: 8px;
    height: 8px;
    border-radius: 50%;
    background: var(--gold);
  }
  .step {
    font-family: var(--display);
    font-size: 0.75rem;
    font-weight: 600;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--blue);
    margin-bottom: 0.35rem;
  }
  .closing { margin-top: 2rem; font-style: italic; color: var(--mid); }
</style>
