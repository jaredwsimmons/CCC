---
import Base from '../layouts/Base.astro';
import PageHero from '../components/PageHero.astro';
import ChurchCenterCalendar from '../components/ChurchCenterCalendar.astro';
---
<Base title="Calendar" description="What's happening at Chelsea Community Church.">
  <PageHero eyebrow="What's happening" title="Church Calendar"
    lead="Services, groups, studies, and events across the life of our church — kept up to date in Church Center.">
    <a class="btn btn--gold" href="/imnew">Plan a visit</a>
  </PageHero>
  <section class="section">
    <div class="container" data-reveal>
      <ChurchCenterCalendar />
    </div>
  </section>
</Base>
