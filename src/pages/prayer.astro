---
import Base from '../layouts/Base.astro';
import PageHero from '../components/PageHero.astro';
import Section from '../components/Section.astro';
import { prayer } from '../data/content';
import { site } from '../data/site';
const prayerForm = `${site.churchCenter.forms.prayer}?open-in-church-center-modal=true`;
---
<Base title="Prayer" description="We want to pray for you — share your prayer concerns with Chelsea Community Church, or join the Prayer Team.">
  <PageHero eyebrow="Prayer" title="We want to pray for you" lead={prayer.cta}>
    <a class="btn btn--gold btn--lg" href={prayerForm}>How can we pray with you?</a>
  </PageHero>

  <Section eyebrow="Our prayer ministry" title="A church where prayer is central">
    <p class="measure" data-reveal>{prayer.ministry}</p>
  </Section>

  <Section variant="alt" eyebrow="Join the prayer team" title="How to get involved">
    <ol class="steps" data-reveal>
      {prayer.joinSteps.map((s) => <li>{s}</li>)}
    </ol>
    <div class="card note measure" data-reveal>
      <h3>A note on privacy</h3>
      <p>{prayer.note}</p>
    </div>
  </Section>
</Base>

<style>
  .steps {
    list-style: none;
    counter-reset: step;
    display: grid;
    gap: 0.9rem;
    max-width: 62ch;
  }
  .steps li {
    counter-increment: step;
    position: relative;
    padding-left: 3rem;
    min-height: 2.2rem;
    display: flex;
    align-items: center;
  }
  .steps li::before {
    content: counter(step);
    position: absolute;
    left: 0;
    top: 0;
    width: 2.2rem;
    height: 2.2rem;
    border-radius: 50%;
    background: var(--gold);
    color: var(--navy);
    font-family: var(--display);
    font-weight: 600;
    display: grid;
    place-items: center;
  }
  .note { margin-top: 2rem; }
</style>
