---
import Base from '../layouts/Base.astro';
import PageHero from '../components/PageHero.astro';
import Section from '../components/Section.astro';
import Icon from '../components/Icon.astro';
import { site } from '../data/site';
// Prayer request form (Church Center) — form id from the site crawl.
const prayerForm = `https://${site.churchCenter.orgSlug}.churchcenter.com/people/forms/876492?open-in-church-center-modal=true`;
---
<Base title="Prayer" description="Share a prayer request with Chelsea Community Church. We would be honored to pray for you.">
  <PageHero eyebrow="Prayer" title="Let us pray with you"
    lead="Whatever you're facing, you don't have to carry it alone. Share a request and our prayer team will lift it to God on your behalf.">
    <a class="btn btn--gold btn--lg" href={prayerForm}>Submit a request</a>
  </PageHero>

  <Section>
    <div class="pray">
      <div data-reveal>
        <p class="eyebrow">Why we pray</p>
        <h2 class="mt-1">We believe God still listens</h2>
        <p class="lead">Prayer isn't a last resort — it's where the Christian life begins and breathes. When you share a request with us, real people pray for you by name.</p>
        <ul class="pray-list">
          <li><Icon name="check" /> Every request is handled with care and confidentiality.</li>
          <li><Icon name="check" /> Our team prays through requests each week.</li>
          <li><Icon name="check" /> Need to talk to someone? A pastor will follow up.</li>
        </ul>
      </div>
      <div class="pray-card" data-reveal data-delay="1">
        <div class="chip chip--gold"><Icon name="hands" /></div>
        <h3>Share a request</h3>
        <p>It only takes a minute, and it stays between you and our prayer team.</p>
        <a class="btn btn--primary" href={prayerForm}>Open the prayer form</a>
      </div>
    </div>
  </Section>

  <Section variant="deep" width="narrow">
    <figure class="pray-quote center" data-reveal>
      <blockquote>"Do not be anxious about anything, but in everything by prayer and supplication with thanksgiving let your requests be made known to God."</blockquote>
      <figcaption>Philippians 4:6</figcaption>
    </figure>
  </Section>
</Base>

<style>
  .pray { display: grid; grid-template-columns: 1.1fr 0.9fr; gap: 2.5rem; align-items: center; }
  .pray-list { list-style: none; padding: 0; margin: 1.5rem 0 0; display: grid; gap: 0.75rem; }
  .pray-list li { display: flex; align-items: flex-start; gap: 0.7rem; color: var(--slate); }
  .pray-list li :global(svg) { color: var(--blue); flex-shrink: 0; margin-top: 2px; }
  .pray-card { background: var(--cream); border: 1px solid #efe6d4; border-radius: var(--r-lg); padding: 2rem; box-shadow: var(--shadow-sm); text-align: left; }
  .pray-card h3 { margin: 0.5rem 0; }
  .pray-card .btn { margin-top: 1rem; }
  .pray-quote blockquote { font-family: var(--font-display); font-size: clamp(1.3rem, 2.6vw, 1.85rem); color: #fff; font-style: italic; line-height: 1.4; }
  .pray-quote figcaption { margin-top: 1.1rem; color: var(--gold-300); font-family: var(--font-display); font-weight: 600; }
  @media (max-width: 820px) { .pray { grid-template-columns: 1fr; } }
</style>
