---
import Base from '../layouts/Base.astro';
import PageHero from '../components/PageHero.astro';
import Section from '../components/Section.astro';
import CTABand from '../components/CTABand.astro';
import DeaconNote from '../components/DeaconNote.astro';
import { missions } from '../data/content';
---
<Base title="Missions" description="Missions at Chelsea Community Church — local, national, and international partners, monthly highlights, and resources for personal growth.">
  <PageHero eyebrow="Ministries" title="Missions" lead={`${missions.verse.text} (${missions.verse.ref})`}>
    <DeaconNote area="Missions" slot="aside" />
  </PageHero>

  <!-- Monthly highlight -->
  <Section eyebrow="Monthly missions highlight" title="The Big Kaboom">
    <div class="split">
      <div data-reveal>
        <p class="measure">{missions.highlight.body}</p>
        <a class="btn btn--blue mt-1" href={`mailto:${missions.contact}`}>Contact Pastor Brian</a>
      </div>
      <div class="photo" data-reveal>
        <img src={missions.highlight.image} alt={missions.highlight.imageAlt} loading="lazy" />
      </div>
    </div>
  </Section>

  <!-- Local partners -->
  <Section variant="alt" eyebrow="Local mission partners" title="Serving our neighbors" center>
    <div class="grid cols-3">
      {missions.local.map((p) => (
        <div class="card partner" data-reveal>
          <h3>{p.name}</h3>
          <p>{p.focus}</p>
          <p class="links">
            {p.url && <a href={p.url} target="_blank" rel="noopener noreferrer">Website</a>}
            {p.newsletter && <a href={p.newsletter} target="_blank" rel="noopener noreferrer">Newsletter</a>}
          </p>
        </div>
      ))}
    </div>
  </Section>

  <!-- Global partners -->
  <Section eyebrow="National & international mission partners" title="To the ends of the earth" center>
    <div class="grid cols-3">
      {missions.global.map((p) => (
        <div class="card partner" data-reveal>
          <h3>{p.name}</h3>
          <p>{p.focus}</p>
          <p class="links">
            {p.url && <a href={p.url} target="_blank" rel="noopener noreferrer">Website</a>}
            {p.newsletter && <a href={p.newsletter} target="_blank" rel="noopener noreferrer">Newsletter</a>}
          </p>
        </div>
      ))}
    </div>
  </Section>

  <!-- Reading -->
  <Section variant="white" eyebrow="Resources for personal growth" title="Books worth your time">
    <ul class="books" data-reveal>
      {missions.resources.map((b) => (
        <li>
          <a href={b.url} target="_blank" rel="noopener noreferrer">{b.title}</a>
          <span> — {b.author}</span>
        </li>
      ))}
    </ul>
  </Section>

  <CTABand title="Ready to get involved?" text="Pray, give, or go — Pastor Brian can help you find your place in the mission.">
    <a class="btn btn--gold btn--lg" href={`mailto:${missions.contact}`}>Email Brian for more information!</a>
  </CTABand>
</Base>

<style>
  .partner { text-align: left; }
  .partner .links { display: flex; gap: 1rem; margin-top: 0.6rem; font-size: 0.92rem; }
  .books { list-style: none; display: grid; gap: 0.7rem; max-width: 68ch; }
  .books li { padding-left: 1.1rem; position: relative; }
  .books li::before {
    content: "";
    position: absolute;
    left: 0;
    top: 0.6em;
    width: 8px;
    height: 8px;
    border-radius: 50%;
    background: var(--gold);
  }
  .books span { color: var(--mid); }
</style>
