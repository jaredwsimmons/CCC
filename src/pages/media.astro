---
import Base from '../layouts/Base.astro';
import PageHero from '../components/PageHero.astro';
import Section from '../components/Section.astro';
import { media, home } from '../data/content';
import { site } from '../data/site';
---
<Base title="Media" description="Watch Chelsea Community Church worship services on YouTube or listen to the sermon podcast on Spotify, Apple Podcasts, and Amazon Music.">
  <PageHero eyebrow="Media" title="Watch & Listen" lead={media.intro[0]} />

  <Section>
    <div class="grid cols-2">
      <div class="card" data-reveal>
        <h3>Watch our worship service</h3>
        <p>{media.intro[1]}</p>
        <a class="btn btn--blue mt-1" href={site.social.youtube} target="_blank" rel="noopener noreferrer">Watch on YouTube</a>
      </div>
      <div class="card" data-reveal>
        <h3>Listen to our sermon podcast</h3>
        <p>{media.intro[2]}</p>
        <div class="pods">
          <a class="btn btn--outline" href={site.social.spotify} target="_blank" rel="noopener noreferrer">Spotify</a>
          <a class="btn btn--outline" href={site.social.applePodcasts} target="_blank" rel="noopener noreferrer">Apple Podcasts</a>
          <a class="btn btn--outline" href={site.social.amazonMusic} target="_blank" rel="noopener noreferrer">Amazon Music</a>
        </div>
      </div>
    </div>
  </Section>

  <Section variant="navy">
    <div class="split">
      <div class="photo" data-reveal>
        <img src={home.series.art} alt={home.series.artAlt} loading="lazy" />
      </div>
      <div data-reveal>
        <p class="eyebrow on-dark">Current sermon series</p>
        <h2>Jesus Storyteller</h2>
        <p style="margin-top:0.9rem">{home.series.body}</p>
        <a class="btn btn--gold mt-1" href={site.media.seriesPlaylist} target="_blank" rel="noopener noreferrer">Watch the series</a>
      </div>
    </div>
  </Section>
</Base>

<style>
  .pods { display: flex; flex-wrap: wrap; gap: 0.6rem; margin-top: 1rem; }
</style>
