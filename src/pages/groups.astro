---
import Base from '../layouts/Base.astro';
import PageHero from '../components/PageHero.astro';
import Section from '../components/Section.astro';
import CTABand from '../components/CTABand.astro';
import DeaconNote from '../components/DeaconNote.astro';
import { groups as groupsContent } from '../data/content';
import { getGroupsByType } from '../lib/groups';
import { site } from '../data/site';

// LIVE from Church Center's public groups API (no token). Full groups hidden.
const sections = await getGroupsByType();
const allGroupsUrl = `https://${site.churchCenter.subdomain}/groups`;
---
<Base title="Community Groups" description="Community groups at Chelsea Community Church — living life within biblical community. Find one that fits and request to join.">
  <PageHero eyebrow="Community groups" title="Life is better together" lead={groupsContent.intro}>
    <DeaconNote area="Adult Discipleship" slot="aside" blurb="Serving and praying over our community groups." />
    <a class="btn btn--gold btn--lg" href={allGroupsUrl} target="_blank" rel="noopener noreferrer">Browse all groups</a>
  </PageHero>

  {sections.map((s) => (
    <Section eyebrow={s.type} title={s.type === 'Community Groups' ? 'Find your community group' : s.type}>
      <div class="grid cols-3">
        {s.groups.map((g) => (
          <div class="card group" data-reveal>
            <span class="tag-cat">Open to join</span>
            <h3>{g.name}</h3>
            {g.schedule && <p class="group__sched">{g.schedule}</p>}
            {g.description && <p>{g.description}</p>}
            <a class="group__join" href={g.joinUrl} target="_blank" rel="noopener noreferrer">Request to join →</a>
          </div>
        ))}
      </div>
    </Section>
  ))}

  <Section variant="alt" tight>
    <p class="note" data-reveal>
      Groups are listed live from <a href={allGroupsUrl} target="_blank" rel="noopener noreferrer">Church Center</a>.
      Full groups aren't shown — if one you love is full, <a href={`mailto:${groupsContent.contact}`}>let us know</a> and we'll help you find a fit.
    </p>
  </Section>

  <CTABand title="Not sure which group fits?" text="Tell us a little about yourself and we'll help you find a group that feels like home.">
    <a class="btn btn--gold btn--lg" href={`mailto:${groupsContent.contact}`}>Email {groupsContent.contactName} for more information!</a>
  </CTABand>
</Base>

<style>
  .tag-cat {
    display: inline-block; font-family: var(--display); font-size: 0.66rem; font-weight: 600;
    letter-spacing: 0.08em; text-transform: uppercase; color: var(--gold-deep);
    background: rgba(240,195,52,0.16); padding: 0.22rem 0.6rem; border-radius: 999px; margin-bottom: 0.55rem;
  }
  .group__sched { font-family: var(--display); font-weight: 600; color: var(--blue); font-size: 0.9rem; margin-top: 0.1rem; }
  .group p { margin-top: 0.5rem; }
  .group__join { display: inline-block; margin-top: 0.9rem; font-family: var(--display); font-weight: 600; font-size: 0.9rem; text-decoration: none; }
  .note { font-size: 0.95rem; color: var(--mid); max-width: 62ch; }
</style>
