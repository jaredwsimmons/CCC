---
import Base from '../layouts/Base.astro';
import PageHero from '../components/PageHero.astro';
import Section from '../components/Section.astro';
import CTABand from '../components/CTABand.astro';
import DeaconNote from '../components/DeaconNote.astro';
import { groups } from '../data/content';
---
<Base title="Community Groups" description="Community groups at Chelsea Community Church — living life within biblical community on Sunday mornings and throughout the week.">
  <PageHero eyebrow="Ministries" title="Community Groups" lead={groups.intro} />

  <Section>
    <div class="grid cols-2">
      {groups.list.map((g) => (
        <div class="card group" data-reveal>
          <p class="when">{g.when}</p>
          <h3>{g.name}</h3>
          <p>{g.desc}</p>
          <p class="room">{g.room}</p>
        </div>
      ))}
    </div>
  </Section>

  <Section tight>
    <DeaconNote area="Adult Discipleship" blurb="Serving and praying over our adult discipleship and community groups — reach out anytime." />
  </Section>

  <CTABand title="Not sure which group fits?" text="Tell us a little about yourself and we'll help you find a group that feels like home.">
    <a class="btn btn--gold btn--lg" href={`mailto:${groups.contact}`}>Email Rebecca for more information!</a>
  </CTABand>
</Base>

<style>
  .group .when {
    font-family: var(--display);
    font-size: 0.78rem;
    font-weight: 600;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--blue);
    margin-bottom: 0.4rem;
  }
  .group .room {
    margin-top: 0.7rem;
    font-family: var(--display);
    font-size: 0.8rem;
    font-weight: 500;
    color: var(--navy);
    background: var(--paper);
    border: 1px solid var(--hair);
    display: inline-block;
    padding: 0.2rem 0.7rem;
    border-radius: 999px;
  }
</style>
