---
import Base from '../layouts/Base.astro';
import PageHero from '../components/PageHero.astro';
import Section from '../components/Section.astro';
import Icon from '../components/Icon.astro';
import CTABand from '../components/CTABand.astro';
import PortableText from '../components/PortableText.astro';
import { urlForImage } from '../lib/image';
import { sanityFetch } from '../lib/sanity';
import { allPagesQuery } from '../lib/queries';
import { ministries, infoPages } from '../data/content';
import { site } from '../data/site';

export async function getStaticPaths() {
  const cms = await sanityFetch<any[]>(allPagesQuery);
  const cmsSlugs = new Set((cms || []).map((p) => p.slug));
  const paths: any[] = [];
  for (const m of ministries) if (!cmsSlugs.has(m.slug)) paths.push({ params: { slug: m.slug }, props: { kind: 'ministry', ministry: m } });
  for (const [slug, page] of Object.entries(infoPages)) if (!cmsSlugs.has(slug)) paths.push({ params: { slug }, props: { kind: 'info', info: { slug, ...page } } });
  for (const p of cms || []) paths.push({ params: { slug: p.slug }, props: { kind: 'cms', page: p } });
  return paths;
}

const props = Astro.props as any;
const connect = `https://${site.churchCenter.subdomain}`;
---
{props.kind === 'ministry' && (() => {
  const m = props.ministry;
  return (
    <Base title={m.name} description={m.tagline}>
      <PageHero eyebrow="Ministries" title={m.name} lead={m.tagline}>
        <a class="btn btn--gold btn--lg" href={connect} target="_blank" rel="noopener noreferrer">{m.cta?.label ?? 'Get connected'}</a>
      </PageHero>

      <Section>
        <div class="mintro" data-reveal>
          <div class="mintro__meta">
            <span class="pill"><Icon name="users" size={16} /> {m.forWho}</span>
            <span class="pill pill--gold"><Icon name="calendar" size={16} /> {m.meets}</span>
          </div>
          <p class="lead">{m.intro}</p>
        </div>
        <div class="grid cols-3 mt-2">
          {m.points.map((pt: any, i: number) => (
            <div class="card" data-reveal data-delay={String((i % 3) + 1)}>
              <div class={`chip ${i === 1 ? 'chip--gold' : ''}`}><Icon name="check" /></div>
              <h3>{pt.title}</h3>
              <p>{pt.text}</p>
            </div>
          ))}
        </div>
      </Section>

      <CTABand title={`Ready to get connected with ${m.name}?`} text="We'd love to help you take the next step." variant="deep">
        <a class="btn btn--gold btn--lg" href={connect} target="_blank" rel="noopener noreferrer">{m.cta?.label ?? 'Get connected'}</a>
      </CTABand>
    </Base>
  );
})()}

{props.kind === 'info' && (() => {
  const p = props.info;
  return (
    <Base title={p.title} description={p.tagline}>
      <PageHero eyebrow="Chelsea Community Church" title={p.title} lead={p.tagline} />
      <Section width="narrow">
        <p class="lead" data-reveal>{p.intro}</p>
        {p.sections && (
          <div class="grid cols-2 mt-2">
            {p.sections.map((s: any, i: number) => (
              <div class="card" data-reveal data-delay={String((i % 2) + 1)}>
                <h3>{s.title}</h3>
                <p>{s.body}</p>
              </div>
            ))}
          </div>
        )}
      </Section>
      <CTABand title="Let's connect" text="However you'd like to take a step, we're here." variant="gold">
        <a class="btn btn--dark btn--lg" href={connect} target="_blank" rel="noopener noreferrer">Reach out</a>
      </CTABand>
    </Base>
  );
})()}

{props.kind === 'cms' && (() => {
  const page = props.page;
  const heroUrl = urlForImage(page.hero)?.width(1600).height(560).url() ?? null;
  const ctaHref = page.cta?.url ? (page.cta.openInModal ? `${page.cta.url}?open-in-church-center-modal=true` : page.cta.url) : null;
  return (
    <Base title={page.title} description={page.tagline ?? undefined}>
      <PageHero eyebrow="Chelsea Community Church" title={page.title} lead={page.tagline ?? undefined}>
        {ctaHref && <a class="btn btn--gold btn--lg" href={ctaHref}>{page.cta.label ?? 'Learn more'}</a>}
      </PageHero>
      <Section width="narrow">
        {page.body ? <div data-reveal><PortableText value={page.body} /></div> : <p class="lead">More details coming soon.</p>}
      </Section>
    </Base>
  );
})()}

<style>
  .mintro__meta { display: flex; flex-wrap: wrap; gap: 0.6rem; margin-bottom: 1.25rem; }
</style>
