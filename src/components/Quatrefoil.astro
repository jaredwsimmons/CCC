---
// The church's quatrefoil mark — a recurring brand device (logo hint, bullets, watermarks).
interface Props { size?: number | string; class?: string; title?: string; }
const { size = 40, class: cls = '', title } = Astro.props;
const dim = typeof size === 'number' ? `${size}px` : size;
---
<svg
  class={`qf ${cls}`}
  width={dim} height={dim} viewBox="0 0 100 100"
  role={title ? 'img' : 'presentation'} aria-hidden={title ? undefined : 'true'} aria-label={title}
  fill="currentColor" xmlns="http://www.w3.org/2000/svg"
>
  {title && <title>{title}</title>}
  <g>
    <circle cx="50" cy="29" r="21" />
    <circle cx="50" cy="71" r="21" />
    <circle cx="29" cy="50" r="21" />
    <circle cx="71" cy="50" r="21" />
    <rect x="33" y="33" width="34" height="34" rx="7" />
  </g>
</svg>
