---
// The church's quatrefoil mark — four lobes joined by concave cusps (a true quatrefoil,
// not a rounded plus). A recurring brand device (logo hint, bullets, watermarks, patterns).
interface Props { size?: number | string; class?: string; title?: string; outline?: boolean; }
const { size = 40, class: cls = '', title, outline = false } = Astro.props;
const dim = typeof size === 'number' ? `${size}px` : size;
const path = 'M25 25 A25 25 0 0 1 75 25 A25 25 0 0 1 75 75 A25 25 0 0 1 25 75 A25 25 0 0 1 25 25 Z';
---
<svg
  class={`qf ${cls}`}
  width={dim} height={dim} viewBox="0 0 100 100"
  role={title ? 'img' : 'presentation'} aria-hidden={title ? undefined : 'true'} aria-label={title}
  xmlns="http://www.w3.org/2000/svg"
>
  {title && <title>{title}</title>}
  {outline
    ? <path d={path} fill="none" stroke="currentColor" stroke-width="1.5" />
    : <path d={path} fill="currentColor" />}
</svg>
