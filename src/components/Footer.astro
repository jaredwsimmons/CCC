---
import { site, nav } from '../data/site';
const year = new Date().getFullYear();
const give = `${site.churchCenter.giving}?open-in-church-center-modal=true`;
const prayerForm = `${site.churchCenter.forms.prayer}?open-in-church-center-modal=true`;
const address = `${site.address.line1}, ${site.address.city}, ${site.address.state} ${site.address.zip}`;
---
<footer class="site-footer">
  <div class="wrap top">
    <div class="id">
      <img src="/images/icon-white.png" alt="" width="64" height="64" loading="lazy" />
      <p class="name">Chelsea Community<br />Church</p>
      <p class="tagline">Pursuing God. <b>Pursuing others.</b></p>
      <p class="times">Sundays · 9:00 &amp; 10:30 AM</p>
    </div>

    <div class="col" aria-labelledby="ftr-touch">
      <h2 id="ftr-touch">Get in Touch</h2>
      <ul>
        <li>
          <span class="label">Address</span>
          <a href={site.address.maps} target="_blank" rel="noopener noreferrer">{address}</a>
        </li>
        <li>
          <span class="label">Phone</span>
          <a href={`tel:+1${site.phone.replaceAll('-', '')}`}>{site.phone}</a>
        </li>
        <li>
          <span class="label">Email us</span>
          <a href={`mailto:${site.email}`}>Get in touch with us, we're here to listen!</a>
        </li>
        <li>
          <span class="label">Prayer</span>
          <a href={prayerForm}>Let us know how we can pray for you.</a>
        </li>
      </ul>
    </div>

    <div class="col" aria-labelledby="ftr-connect">
      <h2 id="ftr-connect">Connect</h2>
      <ul>
        <li><a href={site.social.facebook} target="_blank" rel="noopener noreferrer">Facebook</a></li>
        <li><a href={site.social.instagram} target="_blank" rel="noopener noreferrer">Instagram</a></li>
        <li><a href={site.social.youtube} target="_blank" rel="noopener noreferrer">YouTube</a></li>
        <li><a href={site.social.spotify} target="_blank" rel="noopener noreferrer">Sermon podcast</a></li>
        <li><a href={site.textSignup} target="_blank" rel="noopener noreferrer">Text updates</a></li>
        <li><a href={site.churchCenter.appSetup} target="_blank" rel="noopener noreferrer">Church Center app</a></li>
      </ul>
    </div>

    <div class="col" aria-labelledby="ftr-explore">
      <h2 id="ftr-explore">Explore</h2>
      <ul class="two-col">
        <li><a href="/imnew">I'm New</a></li>
        {nav.flatMap((n) => (n.children ? n.children : n.href === '/imnew' ? [] : [n])).map((l) => (
          <li><a href={l.href}>{l.label}</a></li>
        ))}
        <li><a href={give}>Give</a></li>
      </ul>
    </div>
  </div>

  <div class="wrap bottom">
    <p>Copyright © {year}. All rights reserved. Chelsea Community Church</p>
  </div>
</footer>

<style>
  .top {
    display: grid;
    grid-template-columns: 1.1fr 1.2fr 0.8fr 1fr;
    gap: clamp(1.75rem, 4vw, 3rem);
    padding-block: clamp(2.5rem, 6vw, 3.75rem) 2rem;
  }
  @media (max-width: 960px) { .top { grid-template-columns: 1fr 1fr; } }
  @media (max-width: 560px) { .top { grid-template-columns: 1fr; } }

  .id img { width: 56px; height: 56px; margin-bottom: 0.9rem; }
  .name {
    font-family: var(--display);
    font-weight: 600;
    font-size: 1.15rem;
    line-height: 1.25;
    color: #fff;
  }
  .tagline { margin-top: 0.5rem; font-size: 0.95rem; color: rgba(251, 249, 244, 0.8); }
  .tagline b { color: var(--gold); font-weight: 600; }
  .times { margin-top: 0.35rem; font-size: 0.9rem; color: rgba(251, 249, 244, 0.65); }

  h2 {
    font-family: var(--display);
    font-size: 0.78rem;
    font-weight: 600;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--gold);
    margin-bottom: 0.9rem;
  }
  .col ul { list-style: none; display: flex; flex-direction: column; gap: 0.55rem; }
  .col a { text-decoration: none; font-size: 0.95rem; }
  .col a:hover { text-decoration: underline; }
  .label {
    display: block;
    font-family: var(--display);
    font-size: 0.7rem;
    font-weight: 600;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: rgba(251, 249, 244, 0.55);
  }
  .two-col { display: grid !important; grid-template-columns: 1fr 1fr; gap: 0.45rem 1rem; }

  .bottom {
    border-top: 1px solid rgba(251, 249, 244, 0.15);
    padding-block: 1.1rem;
  }
  .bottom p { font-size: 0.85rem; color: rgba(251, 249, 244, 0.6); }
</style>
