---
import { site, nav } from '../data/site';
const give = `${site.churchCenter.giving}?open-in-church-center-modal=true`;
const path = Astro.url.pathname.replace(/\/$/, '') || '/';
const isActive = (href: string) =>
  href === '/' ? path === '/' : path === href || path.startsWith(href + '/');
---
<div class="topbar">
  <div class="wrap">
    <p class="live">
      <b>Sunday Live Service</b><span> · starts at 9 AM — </span>
      <a href={site.media.youtubeChannel} target="_blank" rel="noopener noreferrer">watch on YouTube</a>
    </p>
    <nav aria-label="Quick links">
      <a href={give}>Give</a>
      <a href="/prayer">Prayer</a>
      <a href={site.textSignup} target="_blank" rel="noopener noreferrer">Text</a>
    </nav>
  </div>
</div>

<header class="site-header">
  <div class="wrap bar">
    <a class="brand" href="/">
      <img src="/images/logo-full-blue.png" alt={`${site.name} — home`} width="232" height="72" />
    </a>

    <button
      class="nav-toggle"
      type="button"
      aria-expanded="false"
      aria-controls="site-nav"
      data-nav-toggle
    >
      <span class="sr-only">Menu</span>
      <span class="nav-toggle__bars" aria-hidden="true"><i></i><i></i><i></i></span>
    </button>

    <nav id="site-nav" class="nav" aria-label="Primary">
      <ul>
        {nav.map((item) =>
          item.children ? (
            <li class="has-menu">
              <a
                href={item.href}
                aria-haspopup="true"
                aria-current={isActive(item.href) ? 'page' : undefined}
              >
                {item.label}
                <svg width="10" height="6" viewBox="0 0 10 6" aria-hidden="true"><path d="M1 1l4 4 4-4" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round"/></svg>
              </a>
              <ul class="menu">
                {item.children.map((c) => (
                  <li><a href={c.href} aria-current={isActive(c.href) ? 'page' : undefined}>{c.label}</a></li>
                ))}
              </ul>
            </li>
          ) : (
            <li>
              <a href={item.href} aria-current={isActive(item.href) ? 'page' : undefined}>{item.label}</a>
            </li>
          )
        )}
        <li class="nav-give"><a class="btn btn--gold" href={give}>Give</a></li>
      </ul>
    </nav>
  </div>
</header>

<script is:inline>
  (function () {
    var btn = document.querySelector('[data-nav-toggle]');
    var nav = document.getElementById('site-nav');
    if (!btn || !nav) return;
    btn.addEventListener('click', function () {
      var open = btn.getAttribute('aria-expanded') === 'true';
      btn.setAttribute('aria-expanded', String(!open));
      document.documentElement.classList.toggle('nav-open', !open);
    });
    // Close the drawer when a link inside it is chosen
    nav.addEventListener('click', function (e) {
      if (e.target.closest('a')) {
        btn.setAttribute('aria-expanded', 'false');
        document.documentElement.classList.remove('nav-open');
      }
    });
  })();
</script>

<style>
  .bar {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
    min-height: var(--hdr-h);
  }
  .brand { display: inline-flex; align-items: center; flex: none; }
  .brand img { width: clamp(170px, 22vw, 232px); height: auto; }

  /* desktop nav */
  .nav ul {
    list-style: none;
    display: flex;
    align-items: center;
    gap: clamp(0.2rem, 1vw, 0.55rem);
  }
  .nav a:not(.btn) {
    display: inline-flex;
    align-items: center;
    gap: 0.35rem;
    font-family: var(--display);
    font-size: 0.88rem;
    font-weight: 600;
    color: var(--navy);
    text-decoration: none;
    padding: 0.55rem 0.65rem;
    border-radius: 8px;
  }
  .nav a:not(.btn):hover { color: var(--blue); background: var(--paper); }
  .nav a[aria-current='page'] { color: var(--blue); }
  .nav-give { margin-left: 0.4rem; }

  /* dropdowns */
  .has-menu { position: relative; }
  .menu {
    position: absolute;
    top: calc(100% + 4px);
    left: 0;
    min-width: 208px;
    background: #fff;
    border: 1px solid var(--hair);
    border-radius: 12px;
    box-shadow: var(--shadow);
    padding: 0.45rem;
    display: none;
    flex-direction: column;
    gap: 1px;
    z-index: 50;
  }
  .menu li { list-style: none; }
  .menu a { width: 100%; }
  .has-menu:hover .menu,
  .has-menu:focus-within .menu { display: flex; }

  /* hamburger */
  .nav-toggle {
    display: none;
    background: none;
    border: 1.5px solid var(--hair);
    border-radius: 10px;
    padding: 0.55rem 0.6rem;
    cursor: pointer;
  }
  .nav-toggle__bars { display: block; width: 20px; }
  .nav-toggle__bars i {
    display: block;
    height: 2px;
    background: var(--navy);
    border-radius: 2px;
    transition: transform 0.2s ease, opacity 0.2s ease;
  }
  .nav-toggle__bars i + i { margin-top: 5px; }
  :global(html.nav-open) .nav-toggle__bars i:nth-child(1) { transform: translateY(7px) rotate(45deg); }
  :global(html.nav-open) .nav-toggle__bars i:nth-child(2) { opacity: 0; }
  :global(html.nav-open) .nav-toggle__bars i:nth-child(3) { transform: translateY(-7px) rotate(-45deg); }

  /* mobile drawer */
  @media (max-width: 980px) {
    .nav-toggle { display: block; }
    .nav {
      position: fixed;
      inset: 0;
      top: 0;
      padding-top: calc(var(--hdr-h) + 34px);
      background: #fff;
      visibility: hidden;
      opacity: 0;
      transition: opacity 0.18s ease, visibility 0.18s ease;
      overflow-y: auto;
      z-index: 55; /* below .site-header (60) so the bar + toggle stay on top */
    }
    :global(html.nav-open) .nav { visibility: visible; opacity: 1; }
    .nav ul { flex-direction: column; align-items: stretch; gap: 0; padding: 0.75rem 1.25rem 2rem; }
    .nav a:not(.btn) { font-size: 1.05rem; padding: 0.7rem 0.5rem; border-radius: 8px; }
    .nav a:not(.btn) svg { display: none; }
    .menu {
      position: static;
      display: flex;
      border: 0;
      box-shadow: none;
      background: transparent;
      padding: 0 0 0 1rem;
      min-width: 0;
    }
    .menu a { font-size: 0.98rem !important; color: var(--mid) !important; }
    .menu a:hover { color: var(--blue) !important; }
    .nav-give { margin: 0.9rem 0.5rem 0; }
    .nav-give .btn { width: 100%; }
  }
</style>
