---
import { site, nav } from '../data/site';
import Quatrefoil from './Quatrefoil.astro';
const giveHref = `${site.churchCenter.giving}?open-in-church-center-modal=true`;
---
<header class="hdr" data-header>
  <input type="checkbox" id="nav-toggle" class="nav-cb" hidden />
  <div class="container hdr__bar">
    <a href="/" class="brand" aria-label={`${site.name} home`}>
      <Quatrefoil size={34} class="brand__mark" />
      <span class="brand__text"><span>Chelsea</span> Community Church</span>
    </a>

    <nav class="nav-desktop" aria-label="Primary">
      <ul>
        {nav.map((item) =>
          item.children ? (
            <li class="has-sub">
              <a href={item.href}>{item.label}<svg width="12" height="12" viewBox="0 0 24 24" aria-hidden="true"><path d="M6 9l6 6 6-6" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round"/></svg></a>
              <div class="submenu">
                <div class="submenu__inner">
                  {item.children.map((c) => (
                    <a href={c.href}>{c.label}</a>
                  ))}
                </div>
              </div>
            </li>
          ) : (
            <li><a href={item.href}>{item.label}</a></li>
          )
        )}
      </ul>
    </nav>

    <div class="hdr__actions">
      <a class="btn btn--gold btn--sm give" href={giveHref}>Give</a>
      <label for="nav-toggle" class="burger" aria-label="Toggle menu">
        <span></span><span></span><span></span>
      </label>
    </div>
  </div>

  <!-- Mobile drawer -->
  <div class="drawer" role="dialog" aria-label="Menu">
    <nav class="drawer__nav">
      <a href="/">Home</a>
      {nav.map((item) => (
        <>
          <a href={item.href} class="drawer__top">{item.label}</a>
          {item.children?.map((c) => <a href={c.href} class="drawer__sub">{c.label}</a>)}
        </>
      ))}
      <a class="btn btn--gold" href={giveHref}>Give</a>
    </nav>
  </div>
</header>

<style>
  .hdr { position: sticky; top: 0; z-index: 60; background: rgba(255,255,255,0.9); backdrop-filter: blur(10px); border-bottom: 1px solid transparent; transition: box-shadow 0.25s, border-color 0.25s, background 0.25s; }
  .hdr.is-scrolled { box-shadow: var(--shadow-sm); border-bottom-color: var(--line); background: rgba(255,255,255,0.96); }
  .hdr__bar { display: flex; align-items: center; gap: 1.25rem; min-height: 74px; }

  .brand { display: flex; align-items: center; gap: 0.6rem; text-decoration: none; margin-right: auto; }
  .brand__mark { color: var(--gold); flex-shrink: 0; }
  .brand__text { font-family: var(--font-display); font-weight: 700; color: var(--navy); font-size: 1.05rem; line-height: 1.05; letter-spacing: -0.02em; }
  .brand__text span { color: var(--blue); }

  .nav-desktop ul { list-style: none; display: flex; align-items: center; gap: 0.15rem; margin: 0; padding: 0; }
  .nav-desktop > ul > li > a {
    display: inline-flex; align-items: center; gap: 0.3rem; padding: 0.55rem 0.85rem; border-radius: var(--pill);
    text-decoration: none; color: var(--ink); font-family: var(--font-display); font-weight: 500; font-size: 0.98rem;
  }
  .nav-desktop > ul > li > a:hover { background: var(--blue-50); color: var(--blue-700); }

  .has-sub { position: relative; }
  .submenu { position: absolute; left: 50%; top: 100%; translate: -50% 0; padding-top: 0.6rem; opacity: 0; visibility: hidden; transform: translateY(6px); transition: all 0.16s ease; }
  .has-sub:hover .submenu, .has-sub:focus-within .submenu { opacity: 1; visibility: visible; transform: translateY(0); }
  .submenu__inner { display: grid; grid-template-columns: 1fr 1fr; gap: 0.1rem; background: #fff; border: 1px solid var(--line); border-radius: var(--r); box-shadow: var(--shadow-lg); padding: 0.5rem; min-width: 320px; }
  .submenu__inner a { padding: 0.55rem 0.75rem; border-radius: 10px; text-decoration: none; color: var(--slate); font-family: var(--font-display); font-weight: 500; font-size: 0.95rem; }
  .submenu__inner a:hover { background: var(--blue-50); color: var(--blue-700); }

  .hdr__actions { display: flex; align-items: center; gap: 0.75rem; }

  .burger { display: none; flex-direction: column; gap: 5px; width: 44px; height: 44px; align-items: center; justify-content: center; cursor: pointer; border-radius: 12px; }
  .burger span { width: 24px; height: 2.5px; background: var(--navy); border-radius: 2px; transition: transform 0.25s, opacity 0.25s; }

  .drawer { display: none; }

  @media (max-width: 940px) {
    .nav-desktop, .give { display: none; }
    .burger { display: flex; }
    .drawer {
      display: block; position: fixed; inset: 74px 0 0; background: #fff;
      transform: translateX(100%); transition: transform 0.3s cubic-bezier(.2,.8,.2,1);
      overflow-y: auto; z-index: 55; border-top: 1px solid var(--line);
    }
    .nav-cb:checked ~ .drawer { transform: translateX(0); }
    .nav-cb:checked ~ .hdr__bar .burger span:nth-child(1) { transform: translateY(7.5px) rotate(45deg); }
    .nav-cb:checked ~ .hdr__bar .burger span:nth-child(2) { opacity: 0; }
    .nav-cb:checked ~ .hdr__bar .burger span:nth-child(3) { transform: translateY(-7.5px) rotate(-45deg); }
    .drawer__nav { display: flex; flex-direction: column; padding: 1.25rem var(--gutter) 3rem; gap: 0.15rem; }
    .drawer__nav a { text-decoration: none; font-family: var(--font-display); color: var(--navy); padding: 0.85rem 0.5rem; border-bottom: 1px solid var(--line-soft); font-size: 1.15rem; font-weight: 600; }
    .drawer__sub { padding-left: 1.5rem !important; color: var(--slate) !important; font-weight: 500 !important; font-size: 1rem !important; }
    .drawer__nav .btn { margin-top: 1.25rem; border-bottom: none; justify-content: center; }
  }
  @media (max-width: 420px) { .brand__text { font-size: 0.92rem; } }
</style>
