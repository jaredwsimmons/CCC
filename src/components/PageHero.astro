---
import Quatrefoil from './Quatrefoil.astro';
interface Props { eyebrow?: string; title: string; lead?: string; }
const { eyebrow, title, lead } = Astro.props;
---
<section class="phero">
  <Quatrefoil size={420} class="phero__wm" />
  <div class="container phero__inner">
    {eyebrow && <p class="eyebrow on-dark" data-reveal>{eyebrow}</p>}
    <h1 data-reveal data-delay="1">{title}</h1>
    {lead && <p class="lead phero__lead" data-reveal data-delay="2">{lead}</p>}
    <div class="phero__actions" data-reveal data-delay="2"><slot /></div>
  </div>
</section>

<style>
  .phero { position: relative; overflow: hidden; background: var(--grad-hero); color: #dbe8f4; padding-block: clamp(3.5rem, 9vw, 6.5rem); }
  .phero::after { content: ""; position: absolute; inset: 0; background-image: radial-gradient(rgba(255,255,255,0.05) 1.2px, transparent 1.2px); background-size: 26px 26px; opacity: 0.6; }
  .phero__wm { position: absolute; right: -80px; top: -100px; color: rgba(255,255,255,0.09); transform: rotate(10deg); }
  .phero__inner { position: relative; max-width: 820px; }
  .phero h1 { color: #fff; }
  .phero__lead { color: #cdddec; max-width: 60ch; margin-top: 1rem; }
  .phero__actions { margin-top: 1.75rem; display: flex; flex-wrap: wrap; gap: 0.75rem; }
  .phero__actions:empty { display: none; }
</style>
