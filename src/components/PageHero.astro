---
// Page hero. With an image: navy-overlay photo hero. Without: quiet paper hero
// with the brand's gold-dash eyebrow — matching the warm, uncluttered guide.
interface Props {
  eyebrow?: string;
  title: string;
  lead?: string;
  image?: string;
  imageAlt?: string;
}
const { eyebrow, title, lead, image, imageAlt = '' } = Astro.props;
---
{image ? (
  <section class="hero phero--img">
    <div class="hero__img" aria-hidden={imageAlt === '' ? 'true' : undefined}>
      <img src={image} alt={imageAlt} loading="eager" fetchpriority="high" />
    </div>
    <div class="wrap inner">
      {eyebrow && <p class="eyebrow on-dark">{eyebrow}</p>}
      <h1>{title}</h1>
      {lead && <p class="lead" style="color:rgba(251,249,244,0.9)">{lead}</p>}
      <div class="actions"><slot /></div>
    </div>
  </section>
) : (
  <section class="phero--paper">
    <div class="wrap inner">
      <div class="phero__main">
        {eyebrow && <p class="eyebrow">{eyebrow}</p>}
        <h1>{title}</h1>
        {lead && <p class="lead">{lead}</p>}
        <div class="actions"><slot /></div>
      </div>
      <div class="phero__aside"><slot name="aside" /></div>
    </div>
  </section>
)}

<style>
  .phero--img .inner { padding-block: clamp(4rem, 11vw, 7.5rem); max-width: none; }
  .phero--img h1 { max-width: 18ch; }
  .phero--img .lead { margin-top: 0.9rem; max-width: 55ch; }

  .phero--paper {
    background: #fff;
    border-bottom: 1px solid var(--hair);
  }
  .phero--paper .inner {
    padding-block: clamp(2.75rem, 7vw, 4.5rem);
    display: flex;
    align-items: flex-start;
    justify-content: space-between;
    gap: 1.5rem 2.5rem;
    flex-wrap: wrap;
  }
  .phero__main { flex: 1 1 460px; min-width: 0; }
  .phero--paper .lead { margin-top: 0.8rem; }
  .phero__aside { flex: 0 1 auto; }
  .phero__aside:empty { display: none; }
  /* on narrow screens the badge drops below the title, full-ish width */
  @media (max-width: 680px) { .phero__aside { flex-basis: 100%; } }

  .actions { display: flex; flex-wrap: wrap; gap: 0.75rem; margin-top: 1.6rem; }
  .actions:empty { display: none; }
</style>
