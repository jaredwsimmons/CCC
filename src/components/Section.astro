---
interface Props {
  variant?: 'default' | 'alt' | 'white' | 'navy';
  tight?: boolean;
  eyebrow?: string;
  title?: string;
  lead?: string;
  center?: boolean;
  id?: string;
  class?: string;
}
const {
  variant = 'default',
  tight = false,
  eyebrow,
  title,
  lead,
  center = false,
  id,
  class: cls = '',
} = Astro.props;
const sectionClass = [
  'section',
  tight ? 'section--tight' : '',
  variant !== 'default' ? `section--${variant}` : '',
  center ? 'center' : '',
  variant === 'navy' ? 'on-dark' : '',
  cls,
]
  .filter(Boolean)
  .join(' ');
const hasHead = eyebrow || title || lead;
---
<section class={sectionClass} id={id}>
  <div class="wrap">
    {hasHead && (
      <div class="section-head" data-reveal>
        {eyebrow && <p class="eyebrow">{eyebrow}</p>}
        {title && <h2>{title}</h2>}
        {lead && <p class="lead" style="margin-top:0.7rem">{lead}</p>}
      </div>
    )}
    <slot />
  </div>
</section>
