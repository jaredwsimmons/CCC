---
import Quatrefoil from './Quatrefoil.astro';
interface Props { title: string; text?: string; variant?: 'gold' | 'deep'; }
const { title, text, variant = 'deep' } = Astro.props;
---
<section class={`ctaband ctaband--${variant}`}>
  <Quatrefoil size={360} class="ctaband__wm" />
  <div class="container ctaband__inner" data-reveal>
    <div>
      <h2>{title}</h2>
      {text && <p class="lead">{text}</p>}
    </div>
    <div class="ctaband__actions"><slot /></div>
  </div>
</section>

<style>
  .ctaband { position: relative; overflow: hidden; }
  .ctaband--deep { background: var(--grad-deep); color: #cdddec; }
  .ctaband--deep h2 { color: #fff; }
  .ctaband--gold { background: var(--grad-gold); color: var(--navy); }
  .ctaband--gold h2 { color: var(--navy); }
  .ctaband--gold .lead { color: #5a4a15; }
  .ctaband__wm { position: absolute; left: -70px; bottom: -130px; color: rgba(255,255,255,0.11); transform: rotate(-8deg); }
  .ctaband--gold .ctaband__wm { color: rgba(6,42,74,0.09); }
  .ctaband__inner { position: relative; padding-block: clamp(2.5rem, 6vw, 4rem); display: flex; align-items: center; justify-content: space-between; gap: 2rem; flex-wrap: wrap; }
  .ctaband__inner h2 { max-width: 20ch; }
  .ctaband__inner .lead { margin-top: 0.5rem; max-width: 46ch; }
  .ctaband__actions { display: flex; flex-wrap: wrap; gap: 0.75rem; }
</style>
