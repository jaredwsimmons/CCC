# --- Sanity (the CMS) ---
# Create a free project at https://www.sanity.io/manage, then copy its Project ID here.
# These are NOT secrets (project id + dataset are public), so the PUBLIC_ prefix is fine.
# The site builds fine WITHOUT these set — it just renders placeholder content until Sanity is wired up.
PUBLIC_SANITY_PROJECT_ID=
PUBLIC_SANITY_DATASET=production
PUBLIC_SANITY_API_VERSION=2024-10-01

# --- Studio (studio/ folder) uses its own SANITY_STUDIO_* vars; see studio/.env.example ---

# --- ESV API (scripture tooltips) ---
# Free key from https://api.esv.org/  →  create an API Application (register it to the church).
# Build-time only + OPTIONAL: the site builds fine without it — scripture references just
# render as plain text until it's set. Local: put the real key in .env (gitignored).
# Production: set ESV_API_KEY as a Cloudflare Pages build environment variable.
ESV_API_KEY=